generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TableStatus {
  available
  occupied
  closing
}

enum TableSessionStatus {
  open
  ordering
  closing
  closed
  // "void": sesión cerrada sin pagar. Refleja la realidad operativa de
  // un bar: cliente que se va sin pagar, cierre administrativo por error,
  // mesa de cortesía no facturada. NO afecta el ledger contable — los
  // Consumption(type=product) ya entraron al revenue al momento de la
  // entrega. El void solo deja trazabilidad para auditoría (¿cuántas
  // mesas anulé este mes? ¿cuál fue la razón más frecuente?).
  void
}

// Razones predefinidas de void. Lista finita para que los reportes
// puedan agruparlas. "other" admite texto libre adicional en
// TableSession.void_other_detail. NO se agregan razones nuevas sin
// migration — mantener este enum chico es lo que le da valor a los
// reportes ("X% de voids fueron por clientes que se fueron").
enum SessionVoidReason {
  customer_left      // Cliente se fue sin pagar
  admin_error        // Sesión abierta por error (mesa equivocada, doble apertura)
  comp               // Cortesía (invitación de la casa)
  other              // Otro motivo — requiere texto en void_other_detail
}

enum QueueStatus {
  pending
  playing
  played
  skipped
}

enum QueueItemSource {
  customer
  house
}

enum OrderRequestStatus {
  pending
  accepted
  rejected
  cancelled
}

enum OrderStatus {
  accepted
  preparing
  ready
  delivered
  cancelled
}

enum ConsumptionType {
  product
  adjustment
  discount
  refund
  // Cash collected mid-session. Stored as a negative amount so the
  // bill total naturally turns into "pending after partial payments"
  // without changing the sum-of-items logic. Real revenue accounting
  // happens upstream — this row is the customer-facing receipt entry.
  partial_payment
}

enum TableKind {
  // Real physical table with a QR code on the surface.
  TABLE
  // Bar-counter / standing-only account opened from the admin. No QR.
  BAR
}

enum PlaybackStatus {
  idle
  buffering
  playing
  paused
}

enum UserRole {
  admin
  staff
}

enum InventoryMovementType {
  restock
  adjustment
  waste
  correction
}

/**
 * Tipos de eventos auditables. Un valor por cada acción sensible que el
 * staff puede hacer. El enum es la lista cerrada — agregar uno requiere
 * migration, lo cual es lo correcto: forzamos a pensar cada vez que se
 * suma un evento nuevo, en lugar de un string libre que termina lleno
 * de inconsistencias.
 */
enum AuditEventKind {
  // Auth — actor anónimo / cuenta atacada
  login_success
  login_failed
  login_locked
  password_reset_requested
  password_reset_completed
  // Bar access code
  access_code_rotated
  // Sesiones de mesa / cuenta
  session_opened_by_admin
  session_marked_paid
  session_closed
  session_voided
  session_partial_payment
  // Cuentas sin mesa (BAR virtual)
  walkin_account_opened
  // Productos
  product_created
  product_updated
  product_activated
  product_deactivated
  // Inventario directo (stock)
  inventory_movement
  // Ajustes de cuenta (cargo/descuento/refund)
  bill_adjustment
  // Reverso de Payment (Bold rechazó, doble cobro, refund a cliente, etc.)
  payment_reversed
  // Transferencia de cuenta entre mesas/barras
  session_transferred
}

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password_hash String
  role          UserRole @default(staff)
  is_active     Boolean  @default(true)
  // Lockout state. We rate-limit at the user level (not just by IP)
  // because a determined attacker can rotate IPs cheaper than they can
  // guess the password. After LOGIN_LOCKOUT_THRESHOLD failed attempts
  // we set `locked_until` and reject every login until it clears.
  failed_attempts   Int       @default(0)
  locked_until      DateTime?
  last_failed_at    DateTime?
  // Password reset flow. The token is a single-use random string sent
  // via email. We store its bcrypt hash, never the raw value, so a DB
  // dump doesn't hand someone a working reset link.
  reset_token_hash  String?
  reset_expires_at  DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

model Table {
  id                     Int            @id @default(autoincrement())
  number                 Int            @unique
  qr_code                String         @unique
  // TABLE = physical table with a QR. BAR = virtual account opened
  // from the admin (bar-counter / standing customer). Bars don't have
  // a usable QR — qr_code stays @unique so we still store a placeholder.
  kind                   TableKind      @default(TABLE)
  status                 TableStatus    @default(available)
  current_session_id     Int?           @unique
  total_consumption      Decimal        @default(0) @db.Decimal(10, 2)
  active_order_count     Int            @default(0)
  pending_request_count  Int            @default(0)
  last_activity_at       DateTime?
  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt
  songs                  Song[]
  queue_items            QueueItem[]
  sessions               TableSession[] @relation("TableSessions")
  current_session        TableSession?  @relation("TableCurrentSession", fields: [current_session_id], references: [id], onDelete: SetNull)

  @@index([kind])
}

model TableSession {
  id                  Int                @id @default(autoincrement())
  // Identidad estable cross-nodo (UUID). Cada nodo (cloud + cada local)
  // genera el suyo al crear la fila; el sync usa esta llave para
  // deduplicar. Ver ARQUITECTURA.md sección 3. Para filas históricas,
  // la migration les asigna UUID retroactivo.
  external_id         String             @unique @default(uuid())
  table_id            Int
  status              TableSessionStatus @default(open)
  total_consumption   Decimal            @default(0) @db.Decimal(10, 2)
  last_consumption_at DateTime?
  opened_at           DateTime           @default(now())
  closed_at           DateTime?
  // Free-form label set by staff at open time (e.g. "Camilo", "Mesa de
  // pie"). Optional for TABLE sessions, expected for BAR sessions so
  // the staff can tell parallel accounts apart in the admin grid.
  custom_name         String?
  // Who initiated the session: a customer scanning the QR ("customer")
  // vs a staff member opening it from the admin ("staff"). Stored as a
  // string instead of an enum so future origins (kiosk, integration,
  // etc.) don't require a migration.
  opened_by           String             @default("customer")
  // Customer-driven flag: "I want the bill". When set, no new
  // OrderRequest can be created for this session until cleared. The session
  // stays `open` and the music/fairness signals are unaffected.
  payment_requested_at DateTime?
  // Admin-driven flag: payment processed. Stays open after this — the
  // table can keep consuming; new orders are still blocked until close.
  // We deliberately keep this as a single timestamp instead of a Payment
  // table because the read model never needs partial-payment math.
  paid_at             DateTime?
  // Void: sesión cerrada SIN cobro. Se setea por POST /table-sessions/:id/void
  // con razón obligatoria. Cuando esto está poblado, `paid_at` queda null
  // y `closed_at` se setea simultáneamente. No reversible — si fue error,
  // hay que registrar un movimiento manual.
  voided_at           DateTime?
  void_reason         SessionVoidReason?
  // Texto libre solo cuando void_reason == "other". Si void_reason es
  // cualquier otra, este campo se ignora en lectura (lo enforce el service).
  void_other_detail   String?
  // Quién hizo el void (admin email o "system" para migraciones legacy).
  // No es FK a User porque también queremos preservar emails de admins
  // borrados — el dato histórico no debe perderse.
  voided_by           String?
  metadata            Json?
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt
  table               Table              @relation("TableSessions", fields: [table_id], references: [id], onDelete: Cascade)
  current_of_table    Table?             @relation("TableCurrentSession")
  order_requests      OrderRequest[]
  orders              Order[]
  consumptions        Consumption[]
  payments            Payment[]

  @@index([table_id, status])
  @@index([status])
}

model Song {
  id                 Int         @id @default(autoincrement())
  // external_id para sync cross-nodo. Ver ARQUITECTURA.md §3.
  external_id        String      @unique @default(uuid())
  youtube_id         String      @unique
  title              String
  duration           Int
  requested_by_table Int?
  created_at         DateTime    @default(now())
  table              Table?      @relation(fields: [requested_by_table], references: [id], onDelete: Cascade)
  queue_items        QueueItem[]
}

model QueueItem {
  id                 Int            @id @default(autoincrement())
  // external_id para sync cross-nodo. Ver ARQUITECTURA.md §3.
  external_id        String         @unique @default(uuid())
  song_id            Int
  table_id           Int?
  priority_score     Decimal        @default(0) @db.Decimal(10, 2)
  status             QueueStatus    @default(pending)
  position           Int
  queued_at          DateTime       @default(now())
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt
  started_playing_at DateTime?
  finished_at        DateTime?
  skipped_at         DateTime?
  // True when this song was queued as the table's 6th, 7th, ... slot —
  // i.e. when there were already MAX_SONGS_PER_TABLE active items at the
  // moment of insertion. Each "extra" song consumes one credit earned by
  // a delivered order >= EXTRA_SONG_CONSUMPTION_THRESHOLD. If admin skips
  // an extra song, its is_extra flag stays true but the credit-spent
  // count excludes `skipped`, so the credit is effectively returned.
  is_extra           Boolean        @default(false)
  // Where this queue item came from. `customer` = a real table queued it
  // through the QR. `house` = the bar-curated playlist auto-fills the
  // queue when no customer songs are pending. House items always have
  // table_id = null and priority_score = 0.
  source             QueueItemSource @default(customer)
  song               Song           @relation(fields: [song_id], references: [id], onDelete: Cascade)
  table              Table?         @relation(fields: [table_id], references: [id], onDelete: Cascade)
  playback_state     PlaybackState?

  @@index([status, position])
  @@index([table_id, status])
  @@index([status, source, position])
}

/**
 * Bar-curated fallback playlist. Loaded one item at a time into the live
 * QueueItem stream when there's no customer music in the queue. Edited
 * only by admin via /admin/musica-base.
 *
 * Songs can belong to multiple categories (vallenato + mix, for example)
 * via the implicit M2M relation. The active category is stored in the
 * `Setting` table under key "house_playlist_active_category_id".
 */
model HousePlaylistItem {
  id             Int       @id @default(autoincrement())
  youtube_id     String    @unique
  title          String
  // Optional — the YouTube validation endpoint may or may not return it.
  artist         String?
  duration       Int
  is_active      Boolean   @default(true)
  sort_order     Int       @default(0)
  last_played_at DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  categories     HousePlaylistCategory[] @relation("HousePlaylistItemCategories")

  @@index([is_active, sort_order])
  @@index([is_active, last_played_at])
}

/**
 * Admin-curated music categories (Mix, Vallenato, Rock, etc.). Names are
 * free-form strings; the only constraint is that name is unique so the
 * admin can't accidentally create two "Vallenato" categories.
 *
 * One category at a time can be marked as "active" — the player picks
 * fallback songs from that category's pool. If the active category has
 * no songs, the system falls back to silence (the UI prevents picking
 * an empty category, but the runtime check protects against deletes).
 */
model HousePlaylistCategory {
  id         Int                 @id @default(autoincrement())
  name       String              @unique
  created_at DateTime            @default(now())
  updated_at DateTime            @updatedAt
  items      HousePlaylistItem[] @relation("HousePlaylistItemCategories")
}

/**
 * Generic key-value bag for cross-cutting toggles. Keys are app-defined
 * strings (e.g. "house_playlist_active_category_id"), values are JSON so
 * we can store ints, strings, or future objects without schema changes.
 */
model Setting {
  key        String   @id
  value      Json
  updated_at DateTime @updatedAt
}

/**
 * Daily-rotating 4-digit numeric code that gates session opening from
 * each device. Generated lazily: when a customer tries to open a session
 * and the active code is older than 24h, the system rotates it to a new
 * random one. Admin can also force a rotation at any time from the
 * dashboard. Only the most recent active row is "the current code" —
 * older rows stay around for audit (we cap at 60 days).
 */
model BarAccessCode {
  id         Int      @id @default(autoincrement())
  code       String   @db.VarChar(4)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  expires_at DateTime
  // The user/email of the admin who triggered a manual regeneration, or
  // null for system-generated rotations.
  rotated_by String?

  @@index([is_active, created_at])
}

model Product {
  id                    Int                  @id @default(autoincrement())
  // Stable identifier independent of name changes. Used by the seed
  // and any future import/integration to upsert without breaking when
  // the operator renames a product. Required + unique — every product
  // needs identity. New products created from the admin UI also get
  // an SKU (auto-generated if the operator doesn't pick one).
  sku                   String               @unique
  name                  String
  description           String?
  price                 Decimal              @db.Decimal(10, 2)
  stock                 Int                  @default(0)
  // Threshold below which the admin UI flags the product as "low stock".
  // 0 = no warning. Operational hint, not enforced anywhere.
  low_stock_threshold   Int                  @default(0)
  is_active             Boolean              @default(true)
  category              String
  created_at            DateTime             @default(now())
  updated_at            DateTime             @updatedAt
  order_items           OrderItem[]
  inventory_movements   InventoryMovement[]
  // Recipe slots THIS product owns (i.e. this is a composite).
  recipe_slots          ProductRecipeSlot[]
  // Reverse side of ProductRecipeOption.component: this product is a
  // component of recipes. Used to forbid hard-deleting components.
  component_of_options  ProductRecipeOption[] @relation("ComponentOf")
  // Reverse side of OrderItemComponent.component_product.
  component_consumption OrderItemComponent[]  @relation("ComponentConsumption")
}

/**
 * "Slot" de una receta: un grupo de unidades del compuesto que se
 * llenan con uno o más componentes. Ejemplos:
 *   - Cubetazo Aguila Negra → 1 slot de 6 unidades, 1 opción (Aguila).
 *   - Cubetazo aguila/poker → 1 slot de 6 unidades, 2 opciones.
 *   - Combo aguila + nectar → 2 slots: cervezas (6) + licor (1).
 *
 * `quantity` es el TOTAL a llenar entre todas las opciones del slot
 * por cada unidad vendida del compuesto. Cuando se valida la
 * composición, la suma de quantity por opción debe ser == slot.quantity.
 */
model ProductRecipeSlot {
  id          Int                   @id @default(autoincrement())
  product_id  Int
  label       String
  quantity    Int
  // Orden visual en la UI. No es identificador; el id manda.
  position    Int                   @default(0)
  created_at  DateTime              @default(now())
  updated_at  DateTime              @updatedAt
  product     Product               @relation(fields: [product_id], references: [id], onDelete: Cascade)
  options     ProductRecipeOption[]

  @@index([product_id])
}

/**
 * Componentes posibles para llenar un slot. `default_quantity` es la
 * sugerencia inicial cuando el operador/cliente abre el selector. La
 * cantidad REAL al vender la decide el flow de la venta; si no se
 * envía nada, se usa el default.
 *
 * Para compuestos FIJOS: 1 opción cuyo default == slot.quantity.
 * Para compuestos ARMABLES: 2+ opciones cuyos defaults suman
 *   slot.quantity (lo enforce el servicio al guardar la receta).
 */
model ProductRecipeOption {
  id                Int                @id @default(autoincrement())
  slot_id           Int
  component_id      Int
  default_quantity  Int
  position          Int                @default(0)
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  slot              ProductRecipeSlot  @relation(fields: [slot_id], references: [id], onDelete: Cascade)
  component         Product            @relation("ComponentOf", fields: [component_id], references: [id], onDelete: Restrict)

  // Una opción única por (slot, componente). No tiene sentido tener
  // "Aguila" listada dos veces como opción del mismo slot.
  @@unique([slot_id, component_id])
  @@index([component_id])
}

/**
 * Registro inmutable de los componentes físicos descontados al
 * aceptar un OrderItem que es de un producto compuesto. Una fila
 * por componente, por unidad. Permite:
 *   - Reversión exacta al cancelar (reponer lo que efectivamente
 *     salió, no el default).
 *   - Analytics reales por SKU físico ("cuántas aguilas se sirvieron
 *     hoy entre individuales y cubetazos").
 *   - Auditoría legal de qué se descontó.
 *
 * `unit_index` permite distinguir cuál de las N unidades del item
 * tuvo qué composición (importante para cubetazos armables donde
 * cada unidad puede ser distinta).
 */
model OrderItemComponent {
  id                   Int       @id @default(autoincrement())
  // external_id para sync cross-nodo. Ver ARQUITECTURA.md §3.
  external_id          String    @unique @default(uuid())
  order_item_id        Int
  component_product_id Int
  quantity             Int
  unit_index           Int
  created_at           DateTime  @default(now())
  order_item           OrderItem @relation(fields: [order_item_id], references: [id], onDelete: Cascade)
  component_product    Product   @relation("ComponentConsumption", fields: [component_product_id], references: [id], onDelete: Restrict)

  @@index([order_item_id])
  @@index([component_product_id])
}

/**
 * Audit-grade record of every manual change to Product.stock that was not
 * caused by an order accept/cancel. Sales (accept lowering stock) and
 * cancellations (refunding stock) are NOT InventoryMovement rows: those are
 * already tracked by Order/OrderItem and do not duplicate here. This table
 * answers the question "why did stock change *outside* of customer flow?".
 */
model InventoryMovement {
  id          Int                   @id @default(autoincrement())
  // external_id para sync cross-nodo. Ver ARQUITECTURA.md §3.
  external_id String                @unique @default(uuid())
  product_id  Int
  type        InventoryMovementType
  // Signed delta applied to Product.stock at the moment of recording. The
  // service layer enforces sign rules per type (restock > 0, waste < 0,
  // adjustment/correction free).
  quantity    Int
  reason      String?
  notes       String?
  created_by  String?
  created_at  DateTime              @default(now())
  product     Product               @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id, created_at])
  @@index([type, created_at])
}

model OrderRequest {
  id                Int                @id @default(autoincrement())
  // external_id para sync cross-nodo. Ver ARQUITECTURA.md §3.
  external_id       String             @unique @default(uuid())
  table_session_id  Int
  status            OrderRequestStatus @default(pending)
  items             Json
  rejection_reason  String?
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  accepted_at       DateTime?
  rejected_at       DateTime?
  cancelled_at      DateTime?
  table_session     TableSession       @relation(fields: [table_session_id], references: [id], onDelete: Cascade)
  order             Order?

  @@index([table_session_id, status])
  @@index([status])
}

model Order {
  id                Int          @id @default(autoincrement())
  // external_id para sync cross-nodo. Ver ARQUITECTURA.md §3.
  external_id       String       @unique @default(uuid())
  table_session_id  Int
  order_request_id  Int          @unique
  status            OrderStatus  @default(accepted)
  accepted_at       DateTime     @default(now())
  delivered_at      DateTime?
  cancelled_at      DateTime?
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt
  table_session     TableSession @relation(fields: [table_session_id], references: [id], onDelete: Cascade)
  order_request     OrderRequest @relation(fields: [order_request_id], references: [id], onDelete: Restrict)
  order_items       OrderItem[]
  consumptions      Consumption[]

  @@index([table_session_id, status])
  @@index([status])
}

model OrderItem {
  id          Int                  @id @default(autoincrement())
  // external_id para sync cross-nodo. Ver ARQUITECTURA.md §3.
  external_id String               @unique @default(uuid())
  order_id    Int
  product_id  Int
  quantity    Int
  unit_price  Decimal              @db.Decimal(10, 2)
  created_at  DateTime             @default(now())
  order       Order                @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product     Product              @relation(fields: [product_id], references: [id], onDelete: Restrict)
  // Componentes físicos descontados (sólo presente cuando product es
  // un compuesto). Vacío para productos simples.
  components OrderItemComponent[]

  @@index([order_id])
  @@index([product_id])
}

model Consumption {
  id                Int             @id @default(autoincrement())
  // external_id para sync cross-nodo. Ver ARQUITECTURA.md §3.
  external_id       String          @unique @default(uuid())
  table_session_id  Int
  // FK a la sesión de caja activa al momento de crear el Consumption.
  // Nullable solo para filas históricas pre-Fase A+; al crear nuevas,
  // el service exige día abierto (`requireOpen()`) y popla el campo.
  cash_register_session_id Int?
  order_id          Int?
  product_id        Int?
  description       String
  quantity          Int             @default(1)
  unit_amount       Decimal         @db.Decimal(10, 2)
  amount            Decimal         @db.Decimal(10, 2)
  type              ConsumptionType @default(product)
  reversed_at       DateTime?
  reverses_id       Int?            @unique
  reason            String?
  notes             String?
  created_by        String?
  created_at        DateTime        @default(now())
  table_session     TableSession    @relation(fields: [table_session_id], references: [id], onDelete: Cascade)
  cash_register     CashRegisterSession? @relation(fields: [cash_register_session_id], references: [id], onDelete: Restrict)
  order             Order?          @relation(fields: [order_id], references: [id], onDelete: SetNull)
  reverses          Consumption?    @relation("ConsumptionReversal", fields: [reverses_id], references: [id], onDelete: SetNull)
  reversal          Consumption?    @relation("ConsumptionReversal")
  // Inversa: el Payment(kind=partial) que enlaza con este Consumption.
  payment           Payment?        @relation("PaymentConsumption")

  @@index([table_session_id, created_at])
  @@index([cash_register_session_id, created_at])
  @@index([order_id])
}

model PlaybackState {
  id               Int            @id @default(autoincrement())
  status           PlaybackStatus @default(idle)
  queue_item_id    Int?           @unique
  started_at       DateTime?
  position_seconds Int?
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  queue_item       QueueItem?     @relation(fields: [queue_item_id], references: [id], onDelete: SetNull)
}

/**
 * Auditoría centralizada. Una fila por acción sensible. Append-only:
 * el servicio solo expone `create` y `list`; no hay update/delete.
 *
 * - `actor_id` referencia User cuando hay sesión admin detrás. Null en
 *   eventos anónimos (login fallido sin user válido, rotación system,
 *   sesión cerrada por proceso automático, etc.).
 * - `actor_label` es el snapshot del nombre/email del actor en el momento
 *   del evento. Lo guardamos para que si después borramos el User la
 *   auditoría no quede sin contexto.
 * - `summary` es la línea humana lista para mostrar en UI.
 * - `metadata` lleva JSON con el contexto adicional (session_id,
 *   product_id, monto, ip, razón, etc.). El servicio decide qué claves
 *   usar según `kind`.
 *
 * IP solo se guarda para eventos de auth — los demás no se benefician.
 */
model AuditLog {
  id          Int            @id @default(autoincrement())
  // external_id para sync cross-nodo. Ver ARQUITECTURA.md §3.
  external_id String         @unique @default(uuid())
  kind        AuditEventKind
  actor_id    Int?
  actor_label String?
  summary     String
  metadata    Json?
  ip          String?
  created_at  DateTime       @default(now())

  @@index([created_at])
  @@index([kind, created_at])
  @@index([actor_id, created_at])
}


// ─── Ingresos extra (servicios accesorios) ─────────────────────────────────
//
// Modela ingresos que NO son ventas del catálogo (sin Product, sin
// TableSession, sin Consumption). Hoy: cobro por uso del baño. Diseñado
// para admitir más tipos sin migraciones (ej. cover, propinas obligatorias).
//
// Reglas anti-fraude:
//   - El precio (`amount`) es FORZADO por el backend según subtype. El
//     frontend NUNCA lo envía. Cualquier valor en el body se ignora.
//   - No existe DELETE: la corrección operativa es marcar `reversed_at`.
//     El registro original queda para auditoría.
//   - `total_amount` se persiste calculado al guardar para que los
//     reportes no tengan que multiplicar a posteriori (quantity * amount).

enum ExtraIncomeType {
  // Servicio de baño con tarifa diferenciada por subtype.
  restroom
  // Ingreso eventual con concepto libre y monto definido por el staff
  // al momento del cobro. Ej: "Bodega de carpas", "Renta de equipo".
  // NO se forzan precios — el operador es el responsable. Útil para
  // casos puntuales que no merecen entrada en el catálogo.
  manual
}

// Subtypes posibles del baño. Texto libre como string para no atarse a
// un enum específico por tipo — si mañana sumamos `cover` con subtype
// (general/preferente) el modelo no tiene que crecer en enums paralelos.
// Validación de valores válidos vive en el service por tipo.
enum ExtraIncomeStatus {
  active
  reversed
}

model ExtraIncome {
  id            Int               @id @default(autoincrement())
  // external_id para sync cross-nodo. Ver ARQUITECTURA.md §3.
  external_id   String            @unique @default(uuid())
  type          ExtraIncomeType
  // Variante dentro del tipo. Para restroom: "male" | "female". Validado
  // en el service según el tipo. Nullable para tipos futuros sin variante.
  subtype       String?
  // Precio unitario FORZADO por backend. Persistido en la fila para que
  // un cambio futuro de tarifa no altere los reportes históricos: cada
  // cobro mantiene el precio que regía en su momento.
  amount        Decimal           @db.Decimal(10, 2)
  quantity      Int               @default(1)
  total_amount  Decimal           @db.Decimal(10, 2)
  status        ExtraIncomeStatus @default(active)
  // Concepto descriptivo del ingreso. Obligatorio para `manual`
  // (descripción operativa: "Bodega carpas Cliente X"); ignorado para
  // tipos predefinidos como `restroom` que ya se describen por subtype.
  concept       String?
  notes         String?
  // Texto libre del staff que registró el cobro. NO es FK a User para
  // sobrevivir borrados del staff (igual que voided_by en TableSession).
  created_by    String?
  created_at    DateTime          @default(now())
  // Campos de reverso. Si status=reversed, los tres deben estar presentes.
  // El service lo enforce.
  reversed_by    String?
  reversed_at    DateTime?
  reverse_reason String?
  // Sesión de caja activa al crear el ingreso. Nullable solo para
  // filas históricas pre-Fase A+; el service exige día abierto.
  cash_register_session_id Int?
  cash_register            CashRegisterSession? @relation(fields: [cash_register_session_id], references: [id], onDelete: Restrict)

  @@index([type, status, created_at])
  @@index([created_at])
  @@index([cash_register_session_id, created_at])
}

// ─── Guarda maletas (servicio con lifecycle + ficha física) ────────────────
//
// Tiene entidad propia (no ExtraIncome) porque modela:
//   - una ficha física numerada (1-30) reusable
//   - lifecycle: active → delivered | incident
//   - búsqueda por nombre / teléfono / ficha
//   - datos del cliente
//
// Precio fijo $5.000 forzado por backend. Igual filosofía anti-fraude.
//
// Constraint operacional: no puede existir más de un LuggageTicket con
// (ticket_number, status=active). Lo enforce un partial unique index
// que solo aplica cuando status='active'. Cuando la maleta se entrega
// o se reporta incidente, la ficha vuelve a estar libre.

enum LuggageStatus {
  active     // Maleta en el bar, ficha entregada al cliente
  delivered  // Maleta entregada al cliente, ficha vuelve al pool
  incident   // Ficha perdida o problema operativo
}

enum LuggagePaymentStatus {
  pending  // Cliente aún no paga
  paid     // Cobrado al ingresar
}

model LuggageTicket {
  id                   Int                  @id @default(autoincrement())
  // external_id para sync cross-nodo. Ver ARQUITECTURA.md §3.
  external_id          String               @unique @default(uuid())
  // Número de la ficha física (1-30 hoy; ampliable cambiando la UI).
  // Validación de unicidad mientras está active vive en el service: la
  // BD garantiza la unicidad con un índice parcial creado en la migration.
  ticket_number        Int
  customer_first_name  String
  customer_last_name   String
  customer_phone       String
  amount               Decimal              @db.Decimal(10, 2)
  payment_status       LuggagePaymentStatus @default(pending)
  status               LuggageStatus        @default(active)
  notes                String?
  created_by           String?
  created_at           DateTime             @default(now())
  // Campos de entrega.
  delivered_by         String?
  delivered_at         DateTime?
  // Campos de incidente.
  incident_reason      String?
  incident_at          DateTime?
  incident_by          String?
  // Sesión de caja activa al crear el ticket. Nullable solo para
  // filas históricas pre-Fase A+; el service exige día abierto.
  cash_register_session_id Int?
  cash_register        CashRegisterSession? @relation(fields: [cash_register_session_id], references: [id], onDelete: Restrict)

  @@index([status, created_at])
  @@index([ticket_number, status])
  @@index([customer_phone])
  @@index([cash_register_session_id, created_at])
}


// ─── Sync infrastructure (Local-primary POS → Cloud backoffice) ──────────
//
// Ver ARQUITECTURA.md §4 para el patrón completo (Transactional Outbox).
//
// La tabla `OutboxEvent` registra cada cambio operativo que debe pushearse
// al cloud. Se escribe en la MISMA transacción que la entidad afectada
// (atomicidad: nunca hay un cambio sin su evento o viceversa). Un worker
// separado consume `status=pending` ordenado por `occurred_at` y la
// drena al cloud.
//
// En esta primera fase la tabla se crea VACÍA y sin productor. Los
// services se conectarán a ella en fases posteriores. Por ahora es solo
// infraestructura preparada para no requerir migration cuando llegue
// el worker.

enum OutboxStatus {
  pending      // creado, esperando ser pusheado
  pushed       // confirmado en cloud
  quarantined  // schema incompatible o error permanente, requiere intervención
}

model OutboxEvent {
  id              BigInt       @id @default(autoincrement())
  // Nodo que generó el evento. En cloud queda "cloud", en cada local
  // queda "local-crown-001", "local-crown-002", etc.
  node_id         String
  // Llave de idempotencia: UUID único por evento emitido. El cloud
  // deduplica con UNIQUE (node_id, idempotency_key). Esto cierra el
  // hueco clásico de reintentos: si el local pushea, cloud aplica, pero
  // el ACK se pierde (timeout), local reintenta — el segundo INSERT
  // colisiona con el unique y se trata como "ya procesado". Sin esto,
  // la deduplicación dependería del upsert por aggregate_id, lo cual
  // funciona pero pierde matiz cuando un mismo aggregate genera varios
  // eventos (ej. order.created + order.delivered del mismo Order).
  idempotency_key String       @default(uuid())
  // Tipo de evento, ej. "session.opened", "consumption.created",
  // "order.delivered". El consumer cloud decide qué hacer según este.
  event_type      String
  // Tabla de la entidad afectada, ej. "TableSession", "Consumption".
  aggregate_type  String
  // external_id de la entidad afectada (UUID). El upsert al cloud se
  // hace por (node_id, aggregate_type, aggregate_id) para materializar
  // la entidad. Pero la deduplicación de EVENTOS (no de entidades) se
  // hace por idempotency_key.
  aggregate_id    String
  // Snapshot completo de la fila al momento del evento. JSON puro para
  // no atar el outbox al schema vigente; el consumer ve qué hacer con
  // cada versión.
  payload         Json
  // Versionado: el cloud puede aceptar/rechazar/migrar payloads viejos
  // según su tolerancia. NO descartar silenciosamente — quarantine + alert.
  schema_version  String
  app_version     String
  occurred_at     DateTime     @default(now())
  status          OutboxStatus @default(pending)
  pushed_at       DateTime?
  push_attempts   Int          @default(0)
  last_error      String?

  // Deduplicación cross-nodo: el cloud rechaza un INSERT con misma
  // (node_id, idempotency_key) — equivale a "ya procesé este evento".
  @@unique([node_id, idempotency_key])
  // El worker filtra por (status, occurred_at) para drenar en orden.
  @@index([status, occurred_at])
  // Para postmortem: "dame todos los eventos de esta sesión".
  @@index([aggregate_type, aggregate_id])
}

// ─── Operational mode ─────────────────────────────────────────────────────
//
// Ver ARQUITECTURA.md §5. Track de transiciones entre modos del sistema
// (CLOUD_NORMAL ↔ LOCAL_PRIMARY ↔ RECOVERY etc.). Crítico para postmortem:
// "¿qué pasó anoche entre las 8 y las 10?" tiene respuesta literal acá.

enum OperationalModeKind {
  CLOUD_NORMAL    // cloud responde + local sincronizado (estado base)
  LOCAL_PRIMARY   // cloud no responde, local operando standalone
  LOCAL_DEGRADED  // cloud OK pero outbox atrasado más de N minutos
  RECOVERY        // cloud volvió, drenando outbox pendiente
  EMERGENCY       // modo manual forzado por staff
  MAINTENANCE     // local apagado intencionalmente (deploy, migration, etc.)
}

model OperationalMode {
  id          BigInt              @id @default(autoincrement())
  node_id     String
  mode        OperationalModeKind
  reason      String?
  // Quién detectó/forzó el cambio. "auto_health_check" para automático,
  // email del admin para manual.
  detected_by String
  started_at  DateTime            @default(now())
  ended_at    DateTime?
  // Métricas snapshot al cierre del modo, útiles para postmortem y
  // dashboard de salud del sync. Se llenan cuando el modo termina.
  events_queued    Int?
  events_synced    Int?
  duration_seconds Int?

  @@index([node_id, started_at])
  @@index([mode, ended_at])
}

// ─── Local health snapshot ────────────────────────────────────────────────
//
// Ver ARQUITECTURA.md §12.5. Foto operativa cada ~5 min del local para
// observabilidad histórica. Permite reconstruir "qué había abierto a las
// 19:15" cuando se reporta pérdida de datos.
//
// Se popula desde un cron interno del worker; cada snapshot es independiente.

model LocalHealthSnapshot {
  id                        BigInt              @id @default(autoincrement())
  node_id                   String
  taken_at                  DateTime            @default(now())
  // Estado operativo capturado.
  open_sessions             Int
  pending_orders            Int
  active_queue_items        Int
  pending_outbox_events     Int
  inventory_movements_today Int
  consumptions_today        Int
  total_revenue_today       Decimal             @db.Decimal(12, 2)
  active_luggage_tickets    Int
  current_mode              OperationalModeKind
  // Salud del sync hacia cloud.
  cloud_reachable           Boolean
  last_successful_push_at   DateTime?
  oldest_pending_event_at   DateTime?

  @@index([node_id, taken_at])
}


// ─── Registro de nodos del sistema ────────────────────────────────────────
//
// Ver ARQUITECTURA.md §3.5. Catálogo formal de cada nodo (cloud + cada
// local). Usado por:
//   - validación de tokens (iss ∈ NodeRegistry where is_active=true)
//   - dashboard "qué locales tengo activos" + último heartbeat
//   - assignment de pools (rangos de fichas LuggageTicket por nodo)
//   - reporte de schema_version desfasada por nodo
//
// El node_id que aparece en OutboxEvent, OperationalMode,
// LocalHealthSnapshot, etc., debe ser una FK lógica a esta tabla
// (no hard FK porque queremos seguir guardando histórico aunque el
// nodo se haya retirado — `is_active=false` en vez de DELETE).

enum NodeType {
  cloud    // Railway / hosting principal
  local    // Mini-PC en un bar
}

model NodeRegistry {
  // PK es el node_id mismo: "cloud", "local-crown-001", etc.
  node_id        String   @id
  name           String   // legible: "Cloud Railway", "Crown 4.90 - Sede Centro"
  type           NodeType
  installed_at   DateTime @default(now())
  // Heartbeat: el nodo se reporta vivo. Si pasa demasiado tiempo sin
  // actualizar, el cloud levanta alerta. NULL = nunca se reportó (recién
  // registrado, todavía no arrancó).
  last_seen_at   DateTime?
  // Versiones reportadas en el último heartbeat. Permite detectar nodos
  // desactualizados sin entrar al mini-PC físicamente.
  app_version    String?
  schema_version String?
  // Soft-delete: nodo retirado del servicio sin perder histórico.
  is_active      Boolean  @default(true)
  // Pool preasignado de LuggageTicket para este nodo. Vacío para cloud
  // (que usa 1-99999 por convención). Para locales: "100000-109999",
  // "110000-119999", etc. Se valida en el service de luggage.
  luggage_ticket_pool_start Int?
  luggage_ticket_pool_end   Int?
  notes          String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([type, is_active])
}


// ─── Cierre de caja (Fase A+) ─────────────────────────────────────────────
//
// CashRegisterSession modela el "día contable" del bar: apertura con
// base de caja, cierre con conteo declarado y cálculo de descuadre.
// Una sesión de caja agrupa todos los Payment, Consumption, ExtraIncome
// y LuggageTicket que se generaron durante su vigencia.
//
// Reglas:
//   - Solo puede existir UNA sesión con status=open simultáneamente
//     (partial unique index `unique_open_cash_register`).
//   - Sin sesión abierta, la mayoría de endpoints operativos rechazan
//     con 412 CASH_REGISTER_CLOSED. Ver `requireOpen()` en service.
//   - `opening_balance` se declara al abrir; obligatorio salvo en el
//     bypass de emergencia (que setea `opened_via_bypass=true` + razón).
//   - Al cerrar: `closing_balance_expected` se calcula sumando todos los
//     Payment(method=efectivo) + opening_balance. `closing_balance_declared`
//     lo digita el staff contando físico. `difference` = declared - expected
//     (negativo si falta plata).
//   - NO se borra. Soft-immutable: cerrada queda como histórico.

enum CashRegisterStatus {
  open
  closed
}

model CashRegisterSession {
  id                          Int                @id @default(autoincrement())
  // external_id para sync cross-nodo. Ver ARQUITECTURA.md §3.
  external_id                 String             @unique @default(uuid())
  status                      CashRegisterStatus @default(open)
  opening_balance             Decimal            @db.Decimal(12, 2)
  // Apertura: quién y cuándo. opened_by guarda el name del actor admin
  // (no FK a User para sobrevivir borrados; mismo patrón que voided_by).
  opened_at                   DateTime           @default(now())
  opened_by                   String?
  opened_via_bypass           Boolean            @default(false)
  opened_bypass_reason        String?
  // Cierre: nullable hasta que se cierra.
  closed_at                   DateTime?
  closed_by                   String?
  closing_balance_declared    Decimal?           @db.Decimal(12, 2)
  closing_balance_expected    Decimal?           @db.Decimal(12, 2)
  // difference = declared - expected. Positivo: sobró; negativo: faltó.
  difference                  Decimal?           @db.Decimal(12, 2)
  // Notas operativas (motivo del descuadre si se sabe, etc).
  notes                       String?
  created_at                  DateTime           @default(now())
  updated_at                  DateTime           @updatedAt

  // Relaciones inversas (entidades cuya creación se atribuye a esta sesión)
  payments        Payment[]
  consumptions    Consumption[]
  extra_incomes   ExtraIncome[]
  luggage_tickets LuggageTicket[]
  expenses        Expense[]

  @@index([status, opened_at])
  @@index([closed_at])
}

// ─── Payment (Fase A+) ────────────────────────────────────────────────────
//
// Registra cada cobro del bar con su método. Vive en paralelo al ledger
// (Consumption sigue siendo source of truth de "qué se cobró por qué"):
// Payment responde "con qué método entró cada peso".
//
// Tipos (PaymentKind):
//   - partial: anticipo durante la sesión de mesa. FK a Consumption(type=
//     partial_payment) opcional para enlazar con la entrada del ledger.
//   - final: cobro al cierre de la cuenta (markPaid). Puede haber N filas
//     para una misma TableSession (cobros divididos: $30k tarjeta +
//     $20k efectivo). consumption_id queda null en estos.
//
// El campo `cash_register_session_id` ata cada Payment al día contable
// en que se generó, garantizando que el cierre de caja agrupe lo
// correcto incluso si cruza medianoche.

enum PaymentMethod {
  efectivo
  tarjeta_bold
  qr_bold
}

enum PaymentKind {
  partial
  final
  reversal
}

// Razón obligatoria al reversar un Payment. Limitada a un enum cerrado
// para que el cierre de día pueda agrupar/auditar por categoría sin
// depender de strings libres. `other` admite detalle vía reason_detail.
enum PaymentReverseReason {
  bold_rejected
  wrong_session
  double_charge
  customer_refund
  test_operation
  staff_error
  other
}

model Payment {
  id                        Int                  @id @default(autoincrement())
  external_id               String               @unique @default(uuid())
  table_session_id          Int
  cash_register_session_id  Int
  method                    PaymentMethod
  kind                      PaymentKind
  amount                    Decimal              @db.Decimal(10, 2)
  // FK opcional al Consumption(type=partial_payment) cuando es kind=partial.
  // Null para kind=final (no hay row de Consumption sintética al cierre).
  consumption_id            Int?                 @unique
  // Self-FK para reversals. Una fila kind=reversal SIEMPRE tiene
  // reverses_id != null y amount con signo opuesto al original
  // (positivo→negativo). El original nunca se borra (append-only),
  // permitiendo audit completo del ciclo.
  reverses_id               Int?                 @unique
  reverse_reason            PaymentReverseReason?
  reverse_reason_detail     String?
  // Campos para extensión futura (referencia de datafono, propina, etc).
  reference                 String?
  notes                     String?
  created_by                String?
  created_at                DateTime             @default(now())

  table_session       TableSession        @relation(fields: [table_session_id], references: [id], onDelete: Cascade)
  cash_register       CashRegisterSession @relation(fields: [cash_register_session_id], references: [id], onDelete: Restrict)
  consumption         Consumption?        @relation("PaymentConsumption", fields: [consumption_id], references: [id], onDelete: SetNull)
  reverses            Payment?            @relation("PaymentReversal", fields: [reverses_id], references: [id], onDelete: Restrict)
  reversed_by         Payment?            @relation("PaymentReversal")

  @@index([table_session_id, created_at])
  @@index([cash_register_session_id, method])
  @@index([method, created_at])
}

// ─── Expense (Fase A+ — Gastos v1) ────────────────────────────────────────
//
// Egresos de caja registrados durante la operación: reposición de
// productos al proveedor, insumos, mantenimiento, servicios pagados
// en el momento, etc. Cada Expense reduce el `expected` del cierre de
// jornada en su método correspondiente:
//   - efectivo      → resta de caja física esperada
//   - tarjeta_bold  → resta del neto Bold del día
//   - qr_bold       → resta del neto Bold del día
//
// Append-only: los errores se corrigen creando una fila kind=reversal
// con amount opuesto (mismo patrón que Payment reversal). El original
// nunca se borra ni se modifica.
//
// `method` reusa PaymentMethod (Fase A+ B2) — los métodos de cobro y
// de gasto son los mismos hoy. Si en el futuro aparece "transferencia
// bancaria" para gastos pero no para cobros, se evaluará separar.

enum ExpenseCategory {
  mercancia        // cervezas, licores, mixers, bebidas
  insumos          // vasos, servilletas, hielo, hieleras
  mantenimiento    // reparaciones, limpieza, fumigación
  servicios        // luz/agua/internet pagados en el momento
  personal         // propinas adelantadas, vales, transporte staff
  otros            // todo lo demás (concepto libre obligatorio)
}

enum ExpenseKind {
  expense    // egreso normal
  reversal   // anulación de un egreso previo (amount opuesto)
}

model Expense {
  id                        Int                  @id @default(autoincrement())
  external_id               String               @unique @default(uuid())
  cash_register_session_id  Int
  method                    PaymentMethod
  category                  ExpenseCategory
  kind                      ExpenseKind          @default(expense)
  // amount POSITIVO para kind=expense, NEGATIVO para kind=reversal.
  // La suma neta de Expenses del día se resta del expected del cierre.
  amount                    Decimal              @db.Decimal(12, 2)
  // Descripción operativa libre — siempre obligatoria. Ej: "Cerveza
  // Aguila ×24 a proveedor X", "Reparación licuadora", "Vale Pedro".
  concept                   String
  // Datos opcionales para reportes/auditoría.
  supplier                  String?
  receipt_number            String?
  notes                     String?
  // Self-FK para reversals. UNIQUE → solo un reverso por Expense.
  reverses_id               Int?                 @unique
  reverse_reason            String?
  created_by                String?
  created_at                DateTime             @default(now())

  cash_register   CashRegisterSession @relation(fields: [cash_register_session_id], references: [id], onDelete: Restrict)
  reverses        Expense?            @relation("ExpenseReversal", fields: [reverses_id], references: [id], onDelete: Restrict)
  reversed_by     Expense?            @relation("ExpenseReversal")

  @@index([cash_register_session_id, method])
  @@index([category, created_at])
  @@index([created_at])
}

// ─── BarBalanceBaseline (Saldo del bar) ────────────────────────────────────
//
// Línea base del "saldo del bar": cuánta plata hay en total (efectivo
// físico + saldo Bold). El valor MOSTRADO nunca se persiste — se deriva:
//
//   efectivo = baseline.cash + Σ (declared − opening) de cada
//              CashRegisterSession CERRADA después de set_at
//   bold     = baseline.bold + Σ (cobros Bold − egresos Bold) de esas
//              mismas sesiones
//
// Append-only: cada corrección manual inserta una fila nueva (la más
// reciente es la activa). Preserva historial completo de quién puso
// qué valor y cuándo — si el saldo "se editó" siempre hay rastro.
//
// La edición requiere un código de autorización validado SERVER-SIDE
// (ver BarBalanceService) — la UI lo pide tras un gesto discreto para
// que el saldo no parezca editable a simple vista.
model BarBalanceBaseline {
  id           Int      @id @default(autoincrement())
  external_id  String   @unique @default(uuid())
  cash_amount  Decimal  @db.Decimal(14, 2)
  bold_amount  Decimal  @db.Decimal(14, 2)
  set_by       String?
  note         String?
  set_at       DateTime @default(now())

  @@index([set_at])
}
